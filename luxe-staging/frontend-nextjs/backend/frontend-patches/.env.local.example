# Next.js frontend environment variables
# IMPORTANT: server-side only (no NEXT_PUBLIC_ prefix)
# These are NEVER exposed to the browser.

# FastAPI backend URL
BACKEND_URL=http://127.0.0.1:8000

# Pre-shared key for server-to-server auth with FastAPI
# Must match INTERNAL_API_KEY in backend's .env
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=paste_same_value_as_backend_internal_api_key

# Optional — only if you also want Next.js to call OpenAI directly
OPENAI_API_KEY=
