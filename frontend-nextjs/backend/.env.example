# ════════════════════════════════════════════════════════════
# LUXE CAPITAL API — Environment Configuration (Phase 2)
# ════════════════════════════════════════════════════════════

# ─── Environment ────────────────────────────────────────────
ENV=dev
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=text

# ─── External APIs ──────────────────────────────────────────
FMP_API_KEY=your_fmp_key_here
OPENAI_API_KEY=you_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Security ───────────────────────────────────────────────
# Generate with:  python scripts/generate_secrets.py
JWT_SECRET=GENERATE_AT_LEAST_32_CHARS
JWT_EXPIRES_MINUTES=1440
INTERNAL_API_KEY=GENERATE_INTERNAL_KEY_HERE

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ─── Database ───────────────────────────────────────────────
# Dev (SQLite — auto-created):
DATABASE_URL=sqlite:///./luxe.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://luxe:secret@db:5432/luxe

# Docker Compose default:
# DATABASE_URL=postgresql://luxe:luxepass@postgres:5432/luxe

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400
CACHE_TTL_AI=21600

# ─── Rate Limits ────────────────────────────────────────────
RATELIMIT_ANON=20/minute
RATELIMIT_FREE=60/minute
RATELIMIT_PRO=300/minute

# ─── Tier Quotas (daily request count) ──────────────────────
TIER_FREE_DAILY_REQUESTS=50
TIER_PRO_DAILY_REQUESTS=1000
TIER_PRO_PRICE_USD=19.0
